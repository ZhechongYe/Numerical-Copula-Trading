    "from rolling_backtest import (\n",
    "    _safe_panel, _select_pair_in_formation, _fit_pair_models, _h_conditionals, EPS,\n",
    ")\n",
    "from copula_marginals import _cdf_from_fit\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Pick the cycle with the largest single-trade winner; falls back to first non-skipped if no trades.\n",
    "trade_df = result[\"trade_log\"]\n",
    "if len(trade_df):\n",
    "    target_cycle = int(trade_df.loc[trade_df[\"net_pnl\"].idxmax(), \"cycle\"])\n",
    "else:\n",
    "    target_cycle = int(result[\"cycle_log\"][~result[\"cycle_log\"][\"skipped\"]].iloc[0][\"cycle\"])\n",
    "\n",
    "panel = _safe_panel(TF)\n",
    "form_h, trade_h = 504, 168\n",
    "start = target_cycle * trade_h\n",
    "formation = panel.iloc[start : start + form_h]\n",
    "trading = panel.iloc[start + form_h : start + form_h + trade_h]\n",
    "top2 = _select_pair_in_formation(formation, gate=\"kss\")\n",
    "fit = _fit_pair_models(top2)\n",
    "sym1, sym2 = fit[\"sym1\"], fit[\"sym2\"]\n",
    "beta1, beta2 = fit[\"beta1\"], fit[\"beta2\"]\n",
    "\n",
    "s1 = trading[\"BTC_USDT\"].to_numpy(dtype=float) - beta1 * trading[sym1].to_numpy(dtype=float)\n",
    "s2 = trading[\"BTC_USDT\"].to_numpy(dtype=float) - beta2 * trading[sym2].to_numpy(dtype=float)\n",
    "u = np.clip(_cdf_from_fit(s1, fit[\"marginal1\"]), EPS, 1 - EPS)\n",
    "v = np.clip(_cdf_from_fit(s2, fit[\"marginal2\"]), EPS, 1 - EPS)\n",
    "h12, h21 = _h_conditionals(u, v, fit[\"copula\"])\n",
    "\n",
    "a_open = result[\"config\"][\"alpha_open\"]\n",
    "a_close = result[\"config\"][\"alpha_close\"]\n",
    "hours = np.arange(len(h12))\n",
    "cyc_trades = trade_df[trade_df[\"cycle\"] == target_cycle]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 4.6))\n",
    "ax.plot(hours, h12, label=r\"$h^{1|2}$\", color=\"#1d3557\", linewidth=1.2)\n",
    "ax.plot(hours, h21, label=r\"$h^{2|1}$\", color=\"#e63946\", linewidth=1.2)\n",
    "ax.axhline(0.5, color=\"#888\", linestyle=\"--\", linewidth=0.8)\n",
    "ax.axhspan(0.5 - a_close, 0.5 + a_close, color=\"#a8dadc\", alpha=0.25,\n",
    "           label=f\"Close zone (|h-0.5|<{a_close})\")\n",
    "ax.axhline(a_open, color=\"#f4a261\", linestyle=\":\", linewidth=0.9,\n",
    "           label=f\"Open thresholds α₁={a_open}\")\n",
    "ax.axhline(1 - a_open, color=\"#f4a261\", linestyle=\":\", linewidth=0.9)\n",
    "\n",
